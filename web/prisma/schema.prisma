generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"   // or "postgresql" if you use postgres
  url      = env("DATABASE_URL")
}

model Bus {
  bus_id        Int      @id @default(autoincrement())
  bus_no        String
  capacity      Int

  // Route as attributes (not entity)
  route_id      String
  route_name    String

  // Timing as attributes
  arrival_time   String
  departure_time String

  driver        Driver?
  conductor     Conductor?
  passes        StudentPass[]
}

model Driver {
  driver_id   Int    @id @default(autoincrement())
  name        String
  phone       String
  license_no  String

  bus_id Int @unique
  bus    Bus  @relation(fields: [bus_id], references: [bus_id])
}

model Conductor {
  conductor_id Int    @id @default(autoincrement())
  name         String
  phone        String

  bus_id Int @unique
  bus    Bus  @relation(fields: [bus_id], references: [bus_id])
}

model Stop {
  stop_id      Int    @id @default(autoincrement())
  stop_name    String
  area         String
  distance_km  Float

  passes StudentPass[]
}

model StudentPass {
  pass_id     Int      @id @default(autoincrement())
  issue_date  DateTime
  valid_till  DateTime
  amount      Float

  bus_id  Int
  stop_id Int

  bus  Bus  @relation(fields: [bus_id], references: [bus_id])
  stop Stop @relation(fields: [stop_id], references: [stop_id])
}